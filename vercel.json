{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "dist/public/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/trpc/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/dist/public/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/**",
      "maxDuration": 60
    }
  }
}