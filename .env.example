# ===========================================
# Scholar Agent 环境变量配置
# ===========================================
# 请复制此文件为 .env 并填写实际值
# 注意：.env 文件包含敏感信息，请勿提交到版本控制

# ===========================================
# AI 模型配置（必需）
# ===========================================

# DeepSeek API 配置（推荐）
# 获取地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com

# 高德地图 API Key（用于天气查询）
# 获取地址：https://lbs.amap.com
AMAP_API_KEY=

# 或者使用 Qwen/Forge API（备选）
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=

# ===========================================
# 安全配置（必需）
# ===========================================

# JWT 签名密钥（生产环境必须设置为强密码）
# 建议使用 32 位以上的随机字符串
JWT_SECRET=your-secret-key-change-in-production

# ===========================================
# 数据库配置（可选）
# ===========================================

# 数据库连接 URL（如使用 MySQL/PostgreSQL）
DATABASE_URL=

# ===========================================
# OAuth 配置（可选）
# ===========================================

# OAuth 服务器地址
OAUTH_SERVER_URL=

# 应用 ID
VITE_APP_ID=scholar-agent

# 所有者 OpenID
OWNER_OPEN_ID=

# ===========================================
# 运行环境
# ===========================================

# 运行环境：development | production
NODE_ENV=development

# ===========================================
# Cloudflare Pages 部署配置
# ===========================================

# API 后端地址（Cloudflare Pages 部署时需要设置）
# 示例：https://your-api-server.com
VITE_API_BASE_URL=
